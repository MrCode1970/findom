{
  "variant": "ledger_first",
  "version": 1,
  "principle": "Normalized ledger is the source for all reporting sheets",
  "sheets": [
    {
      "name": "Transactions",
      "role": "raw_staging",
      "columns": [
        "raw_external_id",
        "raw_date",
        "raw_amount",
        "raw_currency",
        "raw_account",
        "raw_category_hint",
        "raw_description",
        "ingested_at"
      ],
      "range": "A1:H",
      "notes": "Optional diagnostics layer for raw payload tracking"
    },
    {
      "name": "Normalized",
      "role": "source_of_truth_for_showcase",
      "columns": [
        "external_id",
        "date",
        "amount",
        "currency",
        "account",
        "category",
        "description",
        "month",
        "direction",
        "is_refund",
        "abs_amount",
        "category_group",
        "notes_auto"
      ],
      "range": "A1:M",
      "formulas": {
        "month": "=IF(B2=\"\",,DATE(YEAR(B2),MONTH(B2),1))",
        "direction": "=IF(C2=\"\",,IF(C2<0,\"expense\",\"income\"))",
        "is_refund": "=IF(A2=\"\",,REGEXMATCH(LOWER(G2),\"refund|возврат|reversal\"))",
        "abs_amount": "=IF(C2=\"\",,ABS(C2))",
        "category_group": "=IF(F2=\"\",,IFNA(VLOOKUP(F2,Categories!A:B,2,FALSE),\"unmapped\"))",
        "notes_auto": "=IF(A2=\"\",,IF(COUNTIF($A:$A,A2)>1,\"duplicate_external_id\",IF(L2=\"unmapped\",\"category_missing\",\"ok\")))"
      },
      "validation": {
        "currency": [
          "ILS",
          "USD",
          "EUR"
        ],
        "category": "Categories!A:A"
      }
    },
    {
      "name": "Categories",
      "role": "dictionary",
      "columns": [
        "category",
        "category_group",
        "budget_type",
        "is_active"
      ],
      "range": "A1:D",
      "rows": [
        ["groceries", "living", "variable", true],
        ["transport", "mobility", "variable", true],
        ["dining", "lifestyle", "variable", true],
        ["subscriptions", "digital", "fixed", true],
        ["utilities", "housing", "fixed", true],
        ["healthcare", "health", "variable", true],
        ["salary", "income", "fixed", true],
        ["transfer", "balance", "fixed", true],
        ["cashback", "income", "variable", true],
        ["refund", "income", "variable", true],
        ["shopping", "lifestyle", "variable", true],
        ["travel", "mobility", "variable", true],
        ["entertainment", "lifestyle", "variable", true],
        ["fees", "banking", "fixed", true]
      ]
    },
    {
      "name": "Dashboard",
      "role": "summary",
      "blocks": [
        "monthly_pnl",
        "top_expense_categories",
        "refund_impact",
        "data_quality"
      ],
      "formulas": {
        "income_by_month": "=SUMIFS(Normalized!C:C,Normalized!H:H,$A2,Normalized!C:C,\">0\")",
        "expense_by_month": "=SUMIFS(Normalized!C:C,Normalized!H:H,$A2,Normalized!C:C,\"<0\")",
        "net_by_month": "=B2+C2",
        "refund_total": "=SUMIFS(Normalized!C:C,Normalized!J:J,TRUE)",
        "refund_count": "=COUNTIFS(Normalized!J:J,TRUE)",
        "duplicates": "=COUNTIF(Normalized!M:M,\"duplicate_external_id\")",
        "unmapped_categories": "=COUNTIF(Normalized!M:M,\"category_missing\")"
      }
    }
  ],
  "formatting_rules": [
    {
      "sheet": "Normalized",
      "target_range": "A2:M",
      "type": "custom_formula",
      "formula": "=COUNTIF($A:$A,$A1)>1",
      "style": "red_fill",
      "purpose": "highlight_duplicate_external_id"
    },
    {
      "sheet": "Normalized",
      "target_range": "C2:C",
      "type": "number_condition",
      "condition": "<0",
      "style": "red_text",
      "purpose": "expense_color"
    },
    {
      "sheet": "Normalized",
      "target_range": "C2:C",
      "type": "number_condition",
      "condition": ">0",
      "style": "green_text",
      "purpose": "income_color"
    },
    {
      "sheet": "Normalized",
      "target_range": "A2:M",
      "type": "custom_formula",
      "formula": "=$J2=TRUE",
      "style": "yellow_fill",
      "purpose": "highlight_refunds"
    },
    {
      "sheet": "Normalized",
      "target_range": "M2:M",
      "type": "text_not_equal",
      "condition": "ok",
      "style": "orange_fill",
      "purpose": "quality_issues"
    }
  ],
  "demo_dataset": {
    "sheet": "Normalized",
