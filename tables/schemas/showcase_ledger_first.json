{
  "name": "showcase_ledger_first",
  "version": 1,
  "sheets": [
    {
      "title": "Dashboard",
      "columns": [
        {
          "key": "metric",
          "header": "metric",
          "width": 220
        },
        {
          "key": "value",
          "header": "value",
          "width": 180
        }
      ],
      "freeze_rows": 1,
      "filter": false,
      "min_rows": 50,
      "min_cols": 8,
      "clear": true,
      "demo_rows": [
        [
          "total_income",
          ""
