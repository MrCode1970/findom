        [
          "total_expense",
          ""
        ],
        [
          "net",
          ""
        ],
        [
          "operations_count",
          ""
        ]
      ],
      "formulas": [
        {
          "mode": "cell",
          "cell": "B2",
          "formula": "=СУММЕСЛИМН(Normalized!G2:G;Normalized!I2:I;\"income\")"
        },
        {
          "mode": "cell",
          "cell": "B3",
          "formula": "=СУММЕСЛИМН(Normalized!G2:G;Normalized!I2:I;\"expense\")"
        },
        {
          "mode": "cell",
          "cell": "B4",
          "formula": "=B2+B3"
        },
        {
          "mode": "cell",
          "cell": "B5",
          "formula": "=СЧЁТЗ(Normalized!J2:J)"
        }
      ],
      "number_formats": [
        {
          "range": "B2:B4",
          "type": "NUMBER",
          "pattern": "#,##0.00"
        }
      ]
    },
